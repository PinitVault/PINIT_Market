// PINIT-DNA — Prisma Schema
// Database: PostgreSQL
// Purpose: Stores 6-layer image DNA fingerprint records

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // pooler — used by the running app
  directUrl = env("DIRECT_URL")     // direct — used by prisma migrate / db pull
}

// ─── Core DNA Record ──────────────────────────────────────────────────────────

model DnaRecord {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Original file reference
  // "image" prefix kept for backward compatibility — valid for all file types
  imageFilename     String
  imageMimeType     String
  imageSizeBytes    Int
  imageWidthPx      Int?
  imageHeightPx     Int?

  // ── Universal File DNA fields (Phase 0+) ──────────────────────────────────
  // Nullable so existing IMAGE records are unaffected (treated as IMAGE engine)

  // Detected file type e.g. "IMAGE", "PDF", "DOCX"
  // NULL on legacy records means IMAGE (original engine)
  fileType          String?

  // DNA engine version e.g. "2.0.0-universal"
  // NULL on legacy records means original image-only engine "1.0.0"
  engineVersion     String?

  // Universal layer fingerprints JSON (Phase 1+: TXT/CSV/JSON/PDF/etc.)
  // Image records use the separate layer tables instead
  // Format: { layers: UniversalLayerResult[] }
  universalFingerprints Json?

  // SHA-256 of raw file bytes — used for duplicate detection across ALL file types.
  // Populated by universal-file-router (all non-image types) and dna.orchestrator (images).
  // Nullable so legacy records (pre-duplicate-check) are unaffected.
  sha256Hash        String?

  // Schema version for forward compatibility
  schemaVersion     String   @default("1.0.0")

  // Processing status
  status            DnaStatus @default(PENDING)

  // ── Layer fingerprints (one-to-one relations) ──
  cryptoLayer       CryptoLayer?
  structuralLayer   StructuralLayer?
  perceptualLayer   PerceptualLayer?
  semanticLayer     SemanticLayer?
  metadataLayer     MetadataLayer?
  stegoLayer        StegoLayer?

  // Verification history
  verifications     VerificationLog[]

  // Vault storage
  vaultRecord       VaultRecord?

  // Phase 5 — Document intelligence
  ocrRecord         OcrRecord?
  lineageFrom       DocumentLineage[] @relation("LineageFrom")
  lineageTo         DocumentLineage[] @relation("LineageTo")

  // Crawler/Monitoring
  monitorRecords    MonitorRecord[]

  @@map("dna_records")
}

// ─── Layer 1: SHA-256 Cryptographic Hash ─────────────────────────────────────

model CryptoLayer {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // SHA-256 of the raw image bytes
  sha256Hash  String    @db.Char(64)

  // SHA-256 of the normalized image bytes (strips EXIF, re-encodes) for
  // content-identical matching across saves
  normalizedHash String @db.Char(64)

  // BLAKE3 hash for future-proof secondary verification (placeholder)
  blake3Hash  String?   @db.Char(64)

  @@map("crypto_layers")
}

// ─── Layer 2: Structural Fingerprint (edge-based) ─────────────────────────────

model StructuralLayer {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // Canny edge map serialized as base64 PNG thumbnail
  edgeMapB64       String   @db.Text

  // Dominant structural vectors (JSON array of {angle, magnitude})
  edgeVectors      Json

  // 64-bit compact edge signature for fast comparison
  edgeSignature64  String   @db.Char(16)

  // Algorithm used (e.g. "canny", "sobel")
  algorithm        String   @default("canny")

  @@map("structural_layers")
}

// ─── Layer 3: Perceptual Visual Hash (pHash) ─────────────────────────────────

model PerceptualLayer {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // 64-bit DCT-based perceptual hash (hex string)
  pHash64     String    @db.Char(16)

  // 256-bit extended pHash for high-precision matching
  pHash256    String    @db.Char(64)

  // Average hash for fast pre-filter
  aHash64     String    @db.Char(16)

  // Difference hash
  dHash64     String    @db.Char(16)

  @@map("perceptual_layers")
}

// ─── Layer 4: Semantic Color Fingerprint (RGB histogram) ─────────────────────

model SemanticLayer {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // 256-bin RGB histograms (JSON arrays)
  histogramR  Json
  histogramG  Json
  histogramB  Json

  // HSV histogram for hue-dominant matching
  histogramH  Json
  histogramS  Json

  // Dominant colors — top 5 hex codes + percentage coverage
  dominantColors Json

  // Compact 48-bit color fingerprint (hex)
  colorFingerprint String @db.Char(12)

  @@map("semantic_layers")
}

// ─── Layer 5: Metadata Provenance Record ─────────────────────────────────────

model MetadataLayer {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // Raw EXIF extracted as JSON (null if none present)
  exifData    Json?

  // Camera/device fingerprint (make, model, software)
  deviceMake    String?
  deviceModel   String?
  software      String?

  // Capture datetime from EXIF (may differ from upload time)
  capturedAt    DateTime?

  // GPS coordinates if present
  gpsLatitude   Float?
  gpsLongitude  Float?

  // IPTC / XMP fields
  iptcData      Json?
  xmpData       Json?

  // Hash of the metadata block (for tamper detection)
  metadataHash  String   @db.Char(64)

  @@map("metadata_layers")
}

// ─── Layer 6: Hidden AI Signature (LSB Steganography) ────────────────────────

model StegoLayer {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // Whether the signature was successfully embedded
  embedded     Boolean  @default(false)

  // Capacity in bits available in the carrier image
  capacityBits Int?

  // Bits actually used
  usedBits     Int?

  // HMAC of the embedded payload (used during extraction + verification)
  payloadHmac  String   @db.Char(64)

  // LSB channel used: "R", "G", "B", or "alpha"
  channel      String   @default("B")

  // Base image path where signature was embedded (relative to storage root)
  carrierPath  String?

  @@map("stego_layers")
}

// ─── Verification Log ────────────────────────────────────────────────────────

model VerificationLog {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // Overall result
  passed      Boolean

  // Per-layer results (JSON object, keyed by layer name)
  layerResults Json

  // Similarity scores per layer (0.0–1.0)
  similarityScores Json

  // Overall confidence score (0.0–1.0)
  confidenceScore Float

  // Which layers were checked
  layersChecked   String[]

  // Client IP (for audit trail)
  requestIp     String?

  @@map("verification_logs")
}

// ─── Vault Record ─────────────────────────────────────────────────────────────

model VaultRecord {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Link to the DNA record this vault entry protects
  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // Encrypted file on disk — NEVER the original image
  encryptedFilePath   String
  originalFileName    String
  originalMimeType    String
  encryptedSizeBytes  Int
  originalSizeBytes   Int

  // Encryption metadata (key is never stored — derived via HKDF at retrieval)
  encryptionAlgorithm String  @default("AES-256-GCM")
  keyDerivation       String  @default("HKDF-SHA256")
  ivHex               String  @db.Char(24)   // 12-byte IV = 24 hex chars
  authTagHex          String  @db.Char(32)   // 16-byte auth tag = 32 hex chars

  @@map("vault_records")
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  email        String    @unique
  passwordHash String
  fullName     String
  role         UserRole  @default(USER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime

  @@map("refresh_tokens")
}

// ─── Certificates (Phase 2 hardening) ────────────────────────────────────────

model Certificate {
  id               String   @id @default(uuid())
  createdAt        DateTime @default(now())
  certificateId    String   @unique
  dnaRecordId      String
  vaultId          String
  status           CertStatus @default(ACTIVE)
  signature        String   @db.Text
  issuedAt         DateTime @default(now())
  expiresAt        DateTime?
  revokedAt        DateTime?
  revocationReason String?
  issuedByUserId   String?

  @@index([dnaRecordId])
  @@index([vaultId])
  @@map("certificates")
}

// ─── OCR & Semantic Data ──────────────────────────────────────────────────────

model OcrRecord {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  extractedText String?  @db.Text
  wordCount     Int      @default(0)
  confidence    Float    @default(0)
  language      String   @default("eng")
  processingMs  Int      @default(0)
  indexed       Boolean  @default(false)
  ocrStatus     String   @default("PENDING")  // PENDING | PROCESSING | COMPLETE | FAILED
  errorMessage  String?

  @@map("ocr_records")
}

// ─── Document Lineage ─────────────────────────────────────────────────────────

model DocumentLineage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  fromDnaRecordId String
  toDnaRecordId   String
  relation        String   // DUPLICATE | DERIVED_FROM | RELATED | MODIFIED_COPY
  confidence      Float

  fromDnaRecord DnaRecord @relation("LineageFrom", fields: [fromDnaRecordId], references: [id], onDelete: Cascade)
  toDnaRecord   DnaRecord @relation("LineageTo",   fields: [toDnaRecordId],   references: [id], onDelete: Cascade)

  @@unique([fromDnaRecordId, toDnaRecordId])
  @@map("document_lineage")
}

// ─── Audit Events ─────────────────────────────────────────────────────────────

model AuditEvent {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  eventType   String
  userId      String?
  dnaRecordId String?
  vaultId     String?
  filename    String?
  fileType    String?
  ipAddress   String?
  userAgent   String?  @db.Text
  browser     String?
  os          String?
  device      String?
  detail      Json?

  @@index([dnaRecordId])
  @@index([eventType])
  @@index([createdAt])
  @@map("audit_events")
}

// ─── Crawler & Monitoring ─────────────────────────────────────────────────────

model MonitorRecord {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  dnaRecordId   String
  dnaRecord     DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  filename      String
  fileType      String    @default("UNKNOWN")
  status        String    @default("ACTIVE")   // ACTIVE | PAUSED | STOPPED
  checkEveryHrs Int       @default(24)
  lastCheckedAt DateTime?
  nextCheckAt   DateTime?
  totalChecks   Int       @default(0)
  totalMatches  Int       @default(0)

  watchUrls     String[]  // specific URLs to watch (optional)
  crawlResults  CrawlResult[]

  @@index([status])
  @@index([nextCheckAt])
  @@map("monitor_records")
}

model CrawlResult {
  id              String        @id @default(uuid())
  createdAt       DateTime      @default(now())

  monitorRecordId String
  monitorRecord   MonitorRecord @relation(fields: [monitorRecordId], references: [id], onDelete: Cascade)

  url             String        @db.Text
  pageTitle       String?
  foundText       String?       @db.Text
  textLength      Int           @default(0)
  similarity      Float         @default(0)
  matchType       String        @default("NO_MATCH") // DUPLICATE | NEAR_MATCH | POSSIBLE | NO_MATCH
  alertStatus     String        @default("PENDING")  // PENDING | CONFIRMED | DISMISSED
  checkedAt       DateTime      @default(now())

  @@index([monitorRecordId])
  @@index([matchType])
  @@index([alertStatus])
  @@map("crawl_results")
}

// ─── Smart Links Engine ───────────────────────────────────────────────────────

model ShareLink {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // What is being shared
  vaultId     String
  dnaRecordId String
  filename    String
  mimeType    String   @default("application/octet-stream")

  // Unique public token (used in URL: /s/:token)
  token       String   @unique

  // Access policies
  expiresAt   DateTime?        // null = never expires
  maxViews    Int?              // null = unlimited
  viewCount   Int      @default(0)
  isActive    Boolean  @default(true)
  allowDownload Boolean @default(false)
  requireName  Boolean @default(false)  // recipient must enter name
  note         String?  @db.Text        // optional note to recipient

  // ── Extended access policy (Phase: Access Policies / Access Control Matrix)
  oneTimeUse        Boolean  @default(false) // link self-revokes after first VIEWED
  maxDownloads      Int?                      // null = governed by allowDownload only
  downloadCount     Int      @default(0)
  allowedCountries  String[] @default([])     // empty = no restriction (allow-list of ISO country names)
  allowedDeviceTypes String[] @default([])    // empty = no restriction (desktop|mobile|tablet)
  allowedIpPrefixes String[] @default([])     // empty = no restriction (CIDR-ish prefixes, e.g. "203.0.113")

  // ── Identity verification (Phase: Access Policies — Email/OTP gate) ───────
  requireOtp     Boolean  @default(false)
  recipientEmail String?
  otpCodeHash    String?                       // sha256(otp) — never store plaintext
  otpExpiresAt   DateTime?
  otpVerified    Boolean  @default(false)

  // ── Integrity (Phase: Smart Link Generation — HMAC signature) ─────────────
  tokenSignature String?

  // ── Privacy Masking (viewer-layer only — original file NEVER modified) ────
  privacyMaskingEnabled Boolean  @default(false)
  maskEmail             Boolean  @default(false)
  maskPhone             Boolean  @default(false)
  maskAadhaar           Boolean  @default(false)
  maskPan               Boolean  @default(false)
  maskAddress           Boolean  @default(false)
  maskCustomPatterns    String?  // JSON array of custom regex strings

  // ── GPS Location Request ──────────────────────────────────────────────────
  requestLocation  Boolean  @default(false)  // ask recipient for GPS permission

  // Relations
  accessLogs   ShareAccessLog[]
  unmaskRequests UnmaskRequest[]

  @@index([token])
  @@index([vaultId])
  @@index([dnaRecordId])
  @@map("share_links")
}

// ─── Privacy Masking — Unmask Access Requests ────────────────────────────────

model UnmaskRequest {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())
  reviewedAt  DateTime?

  shareToken    String
  shareLink     ShareLink @relation(fields: [shareToken], references: [token], onDelete: Cascade)

  recipientName String?
  sessionId     String?
  ipAddress     String?
  device        String?
  browser       String?
  os            String?

  // PENDING | APPROVED | REJECTED
  status        String    @default("PENDING")
  reviewNote    String?   // owner's optional note on decision

  @@index([shareToken])
  @@index([status])
  @@map("unmask_requests")
}

model ShareAccessLog {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  shareLinkId String
  shareLink   ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)

  // Who accessed
  recipientName String?  // if requireName = true
  ipAddress   String?
  userAgent   String?   @db.Text
  browser     String?
  os          String?
  device      String?   // desktop | mobile | tablet
  country     String?
  city        String?
  region      String?   // ── Geo Intelligence: now persisted (was fetched but dropped)
  isp         String?   // ── Geo Intelligence: ISP / org name from ip-api.com
  timezone    String?
  referrer    String?   @db.Text

  // ── Device Fingerprinting extensions ──────────────────────────────────────
  screenResolution String?  // "1920x1080" — sent by client
  deviceFingerprint String? // sha256 hash of canvas+webgl+fonts signature

  // ── AI Risk Engine — computed at write-time from event + context history ──
  riskScore   Int?      // 0-100
  riskLevel   String?   // LOW | MEDIUM | HIGH | CRITICAL
  riskFactors String?   @db.Text // JSON array of human-readable reasons

  // ── Session Monitoring — duration of the session this event belongs to ────
  sessionDurationSec Int?

  // ── GPS Location (optional — user consent required) ───────────────────────
  gpsLat        Float?    // latitude  (null if denied / not requested)
  gpsLng        Float?    // longitude
  gpsAccuracy   Float?    // accuracy radius in metres
  gpsCity       String?   // reverse-geocoded city name
  gpsTimestamp  DateTime? // when the browser captured the position
  locationShared Boolean  @default(false) // true=allowed, false=denied/skipped

  // What happened
  action      String    // VIEWED | DOWNLOADED | BLOCKED_* | COPY_ATTEMPT | SCREENSHOT_ATTEMPT | ...
  sessionId   String?   // groups events in one visit

  @@index([shareLinkId])
  @@index([action])
  @@index([sessionId])
  @@map("share_access_logs")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  ANALYST
  AUDITOR
  USER
}

enum CertStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum DnaStatus {
  PENDING      // Upload received, processing not started
  PROCESSING   // Fingerprint generation in progress
  COMPLETE     // All 6 layers generated successfully
  PARTIAL      // Some layers failed; partial DNA stored
  FAILED       // Generation failed entirely
}
