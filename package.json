{
  "name": "pinit-dna",
  "version": "1.0.0",
  "description": "Persistent Image DNA Fingerprint System — 6-layer image identity and verification engine",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc --project tsconfig.json",
    "build:client": "cd client && npm run build",
    "build:all": "npm run build:client && npm run build",
    "start": "node dist/app.js",
    "start:prod": "NODE_ENV=production node dist/app.js",
    "build:start": "npm run build:all && npm run start:prod",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@types/axios": "^0.9.36",
    "@types/bcryptjs": "^2.4.6",
    "@types/diff": "^7.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "diff": "^9.0.0",
    "dotenv": "^16.4.5",
    "exifr": "^7.1.3",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.3.1",
    "file-type": "^16.5.4",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "music-metadata": "^7.14.0",
    "node-cron": "^4.2.1",
    "pdf-parse": "^1.1.1",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "uuid": "^10.0.0",
    "vectra": "^0.15.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jszip": "^3.4.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^5.14.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
